DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
PROJECT_HELPER_DATA_DIR=.project-helper-data
PROJECT_HELPER_ALLOWED_HOSTS=github.com,www.github.com
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1

# SSL: only needed if Python HTTPS requests fail with "CERTIFICATE_VERIFY_FAILED"
# On macOS Python.org builds, the app auto-detects certifi's CA bundle.
# Override manually if needed: SSL_CERT_FILE=/etc/ssl/cert.pem
